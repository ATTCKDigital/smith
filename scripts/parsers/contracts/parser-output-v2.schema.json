{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/ATTCKDigital/smith/specs/20-manifest-fixes/contracts/parser-output-v2.schema.json",
  "title": "Smith Manifest Parser Output (v2 — Structural Only)",
  "description": "JSON shape emitted by parse-python.py and parse-js.js after the v2 update. STRUCTURALLY IDENTICAL to v1 (specs/19-manifest-system/contracts/parser-output.schema.json) except that each function entry and each class method entry now carries a stable 16-char hex `id` field. The parser emits structural data only. Descriptions are generated by a separate LLM layer (`/smith-index --describe` or smith workflow updates) and live in `.meta` files, NOT in parser output. The v1 `docstring` field continues to be PERMITTED on function entries (some legacy parsers may still emit it) but the render layer ignores it.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "path",
    "language",
    "lines",
    "functions",
    "classes",
    "imports",
    "routes",
    "exports",
    "errors"
  ],
  "properties": {
    "path": {
      "type": "string",
      "minLength": 1,
      "description": "Source file path as passed to the parser. May be absolute or project-relative."
    },
    "language": {
      "type": "string",
      "enum": ["python", "javascript", "typescript"],
      "description": "Detected language. JSX collapses to javascript; TSX to typescript."
    },
    "lines": {
      "type": "integer",
      "minimum": 0,
      "description": "Total line count of the source file, including blank lines."
    },
    "functions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "line", "params"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9a-f]{16}$",
            "description": "Stable per-method id. 16-char lowercase hex (64-bit truncated SHA-256). Recipe: sha256(f'{module_path}::{scope_chain}::{name}::{canonical_signature}').hexdigest()[:16]. Stable across body edits and reorderings; changes on rename, signature change, or file move."
          },
          "name": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 1 },
          "params": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["name"],
              "properties": {
                "name": { "type": "string", "minLength": 1 },
                "type": { "type": ["string", "null"] },
                "default": { "type": "string" }
              }
            }
          },
          "return_type": { "type": ["string", "null"] },
          "docstring": {
            "type": ["string", "null"],
            "description": "v1 field, PERMITTED but DEPRECATED in v2. Parsers MAY still emit it; the render layer IGNORES it. v2 descriptions never come from this field — they come from `/smith-index --describe` or smith-workflow in-context updates and live exclusively in `.meta` files."
          },
          "is_async": { "type": "boolean" }
        }
      }
    },
    "classes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "line", "methods"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 1 },
          "methods": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "name", "line"],
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^[0-9a-f]{16}$",
                  "description": "Stable per-method id (same recipe as functions[].id). scope_chain for class methods is the enclosing class name."
                },
                "name": { "type": "string", "minLength": 1 },
                "line": { "type": "integer", "minimum": 1 }
              }
            }
          },
          "bases": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "imports": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["line", "name", "kind"],
        "properties": {
          "line": { "type": "integer", "minimum": 1 },
          "name": { "type": "string", "minLength": 1, "description": "Module path or package name." },
          "kind": {
            "type": "string",
            "enum": ["import", "from", "require", "dynamic"]
          },
          "imported": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Names imported from the module (for 'from X import a, b' and 'import {a, b} from \"X\"')."
          },
          "alias": { "type": "string" }
        }
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["method", "path", "line", "function"],
        "properties": {
          "method": {
            "type": "string",
            "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS", "ANY"]
          },
          "path": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 1 },
          "function": { "type": "string", "minLength": 1, "description": "Handler function name." },
          "framework": {
            "type": "string",
            "enum": ["fastapi", "flask", "express", "unknown"],
            "description": "Detected framework. Optional."
          }
        }
      }
    },
    "exports": {
      "type": "array",
      "description": "JS/TS only. Empty array for Python.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "line", "kind"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "line": { "type": "integer", "minimum": 1 },
          "kind": {
            "type": "string",
            "enum": ["named", "default", "module-level", "react-component"]
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "description": "Populated on parse failures. Empty array means clean parse.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["message"],
        "properties": {
          "line": { "type": "integer", "minimum": 0 },
          "col": { "type": "integer", "minimum": 0 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
